{
  "name": "usermaven-wizard-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Usermaven installation, instrumentation, and verification tooling.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "prettier": "3.9.5",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
