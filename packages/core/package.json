{
  "name": "@usermaven/wizard-core",
  "version": "0.11.0",
  "description": "Local inspection and planning engine for Usermaven Wizard.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usermaven/wizard.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/usermaven/wizard/issues",
  "homepage": "https://github.com/usermaven/wizard#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@usermaven/wizard-schemas": "0.11.0",
    "diff": "9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
